<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Helioscope Lite Demo</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background: #f4f4f4;
      margin: 0;
      padding: 20px;
    }
    h1 {
      color: #2c3e50;
    }
    input {
      padding: 10px;
      margin: 10px;
      border: 1px solid #ccc;
      border-radius: 6px;
    }
    button {
      padding: 10px 20px;
      background: #27ae60;
      border: none;
      border-radius: 6px;
      color: white;
      cursor: pointer;
    }
    button:hover {
      background: #219150;
    }
    .result {
      margin-top: 20px;
      font-size: 18px;
      font-weight: bold;
      color: #333;
    }
  </style>
</head>
<body>
  <h1>☀️ Helioscope Lite (Demo)</h1>
  <p>Enter Solar Panel Power (Watts):</p>
  <input type="number" id="powerInput" placeholder="e.g. 585" />
  <br />
  <button onclick="calculate()">Calculate Energy</button>
  <div class="result" id="result"></div>

  <script>
    function calculate() {
      let power = document.getElementById("powerInput").value;
      if (!power) {
        document.getElementById("result").innerText = "⚠️ Please enter a value.";
        return;
      }
      let energyPerDay = power * 4.5; // approx sunlight hours
      document.getElementById("result").innerText =
        "⚡ Estimated daily energy: " + energyPerDay + " Wh";
    }
  </script>
</body>
</html>
